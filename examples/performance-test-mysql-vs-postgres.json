{
  "source": {
    "type": "mysql",
    "name": "source-mysql",
    "connection": {
      "url": "jdbc:mysql://localhost:3306/consilens_demo",
      "username": "${env.MYSQL_USER}",
      "password": "${env.MYSQL_PASSWORD}"
    },
    "resource": {
      "type": "table",
      "name": "consilens_performance_demo_table"
    }
  },
  "target": {
    "type": "postgresql",
    "name": "target-postgresql",
    "connection": {
      "url": "jdbc:postgresql://localhost:5432/postgres?currentSchema=public",
      "username": "${env.PG_USER}",
      "password": "${env.PG_PASSWORD}"
    },
    "resource": {
      "type": "table",
      "name": "consilens_performance_demo_table"
    }
  },
  "comparison": {
    "keys": {
      "source": [
        "record_id"
      ],
      "target": [
        "record_id"
      ]
    },
    "fields": {
      "source": [
        "col_tinyint",
        "col_smallint",
        "col_mediumint",
        "col_int",
        "col_bigint",
        "col_unsigned_int",
        "col_double",
        "col_decimal",
        "col_numeric",
        "col_char",
        "col_varchar_50",
        "col_varchar_100",
        "col_varchar_255",
        "col_text",
        "col_mediumtext",
        "col_binary",
        "col_varbinary",
        "col_blob",
        "col_date",
        "col_datetime",
        "col_timestamp",
        "col_time",
        "col_boolean",
        "col_tinyint_bool",
        "col_enum",
        "col_set",
        "col_json",
        "user_name",
        "email",
        "phone",
        "address",
        "city",
        "country",
        "postal_code",
        "amount",
        "balance",
        "credit_limit",
        "status",
        "category",
        "priority",
        "score",
        "created_at",
        "updated_at"
      ],
      "target": [
        "col_tinyint",
        "col_smallint",
        "col_mediumint",
        "col_int",
        "col_bigint",
        "col_unsigned_int",
        "col_double",
        "col_decimal",
        "col_numeric",
        "col_char",
        "col_varchar_50",
        "col_varchar_100",
        "col_varchar_255",
        "col_text",
        "col_mediumtext",
        "col_binary",
        "col_varbinary",
        "col_blob",
        "col_date",
        "col_datetime",
        "col_timestamp",
        "col_time",
        "col_boolean",
        "col_tinyint_bool",
        "col_enum",
        "col_set",
        "col_json",
        "user_name",
        "email",
        "phone",
        "address",
        "city",
        "country",
        "postal_code",
        "amount",
        "balance",
        "credit_limit",
        "status",
        "category",
        "priority",
        "score",
        "created_at",
        "updated_at"
      ]
    }
  },
  "strategy": {
    "mode": "checksum",
    "algorithm": "xor",
    "bisectionFactor": 8,
    "bisectionThreshold": 8000,
    "batchSize": 1000,
    "enableProfiling": true
  },
  "concurrency": {
    "io": {
      "core": 8,
      "max": 32,
      "queueSize": 10000,
      "keepAliveSeconds": 60,
      "threadNamePrefix": "consilens-io-"
    },
    "cpu": {
      "core": 4,
      "max": 8,
      "queueSize": 10000,
      "keepAliveSeconds": 60,
      "threadNamePrefix": "consilens-cpu-"
    }
  },
  "result": {
    "sinks": [
      {
        "format": "table",
        "type": "result",
        "properties": {
          "type": "mysql",
          "url": "jdbc:mysql://localhost:3306/diff_results?useUnicode=true&characterEncoding=UTF-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true",
          "username": "${env.MYSQL_USER}",
          "password": "${env.MYSQL_PASSWORD}",
          "driver": "com.mysql.cj.jdbc.Driver",
          "maxPoolSize": 10,
          "tableName": "dv_actual_values",
          "suffixTimestamp": true,
          "createTable": true,
          "dropIfExists": false,
          "defaultColumnLength": 500,
          "batchSize": 1000,
          "columns": [
            {
              "name": "job_execution_id",
              "defaultValue": "12121212",
              "columnType": "bigint(20)"
            },
            {
              "name": "metric_name",
              "defaultValue": "multi_table_accuracy",
              "columnType": "varchar(255)"
            },
            {
              "name": "unique_code",
              "defaultValue": "6JM4IH1FQCZTC2ZEMDQ8UVCGNJXQZLAU14MBUNSS3NC=",
              "columnType": "varchar(255)"
            },
            {
              "name": "actual_value",
              "value": "${totalDifferences}",
              "columnType": "decimal(20,4)"
            },
            {
              "name": "data_time",
              "defaultValue": "2025-05-26 22:35:35",
              "columnType": "datetime"
            },
            {
              "name": "create_time",
              "defaultValue": "2025-05-26 22:35:35",
              "columnType": "datetime"
            },
            {
              "name": "update_time",
              "defaultValue": "2025-05-26 22:35:35",
              "columnType": "datetime"
            }
          ]
        }
      },
      {
        "format": "table",
        "type": "result",
        "properties": {
          "type": "mysql",
          "url": "jdbc:mysql://localhost:3306/diff_results?useUnicode=true&characterEncoding=UTF-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true",
          "username": "${env.MYSQL_USER}",
          "password": "${env.MYSQL_PASSWORD}",
          "driver": "com.mysql.cj.jdbc.Driver",
          "maxPoolSize": 10,
          "tableName": "dv_job_execution_result",
          "suffixTimestamp": true,
          "createTable": true,
          "dropIfExists": false,
          "defaultColumnLength": 500,
          "batchSize": 1000,
          "columns": [
            {
              "name": "job_id",
              "columnType": "bigint(20)",
              "defaultValue": "11111111"
            },
            {
              "name": "job_execution_id",
              "defaultValue": "121212122",
              "columnType": "bigint(20)"
            },
            {
              "name": "metric_unique_key",
              "defaultValue": "21312313",
              "columnType": "varchar(255)"
            },
            {
              "name": "metric_type",
              "defaultValue": "multi_table_accuracy",
              "columnType": "varchar(255)"
            },
            {
              "name": "metric_dimension",
              "columnType": "varchar(255)",
              "defaultValue": "accuracy"
            },
            {
              "name": "metric_name",
              "defaultValue": "multi_table_accuracy",
              "columnType": "varchar(255)"
            },
            {
              "name": "catalog_name",
              "columnType": "varchar(128)",
              "defaultValue": ""
            },
            {
              "name": "schema_name",
              "columnType": "varchar(128)",
              "defaultValue": ""
            },
            {
              "name": "database_name",
              "columnType": "varchar(128)",
              "defaultValue": "consilens_demo"
            },
            {
              "name": "table_name",
              "columnType": "varchar(128)",
              "defaultValue": "consilens_performance_demo_table"
            },
            {
              "name": "column_name",
              "columnType": "varchar(128)",
              "defaultValue": "record_id"
            },
            {
              "name": "actual_value",
              "value": "${totalDifferences}",
              "columnType": "decimal(38,4)"
            },
            {
              "name": "expected_value",
              "columnType": "decimal(38,4)",
              "defaultValue": "${sourceRowCount}"
            },
            {
              "name": "expected_type",
              "columnType": "varchar(255)",
              "defaultValue": "none"
            },
            {
              "name": "result_formula",
              "columnType": "varchar(255)",
              "defaultValue": "count"
            },
            {
              "name": "statistics_json",
              "columnType": "text",
              "defaultValue": "${statistics_json}"
            },
            {
              "name": "operator",
              "columnType": "varchar(255)",
              "defaultValue": "lte"
            },
            {
              "name": "threshold",
              "columnType": "decimal(20,4)",
              "defaultValue": "0.0000"
            },
            {
              "name": "score",
              "defaultValue": "0.0000",
              "columnType": "decimal(20,4)"
            },
            {
              "name": "state",
              "defaultValue": "1",
              "columnType": "int(11)"
            },
            {
              "name": "create_time",
              "defaultValue": "2025-05-26 22:35:35",
              "columnType": "datetime"
            },
            {
              "name": "update_time",
              "defaultValue": "2025-05-26 22:35:35",
              "columnType": "datetime"
            }
          ]
        }
      },
      {
        "format": "table",
        "type": "diff-record",
        "properties": {
          "type": "mysql",
          "url": "jdbc:mysql://localhost:3306/diff_results?useUnicode=true&characterEncoding=UTF-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true",
          "username": "${env.MYSQL_USER}",
          "password": "${env.MYSQL_PASSWORD}",
          "driver": "com.mysql.cj.jdbc.Driver",
          "maxPoolSize": 10,
          "prefix": "diff_results_",
          "suffixTimestamp": true,
          "createTable": true,
          "dropIfExists": false,
          "defaultColumnLength": 500,
          "batchSize": 1000,
          "mergeDefaults": true,
          "columns": [
            {
              "name": "nl_dq_execution_id",
              "defaultValue": "121212122",
              "columnType": "bigint(20)"
            }
          ]
        }
      }
    ]
  }
}
